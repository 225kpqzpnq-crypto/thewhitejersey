{
  "redirects": [
    {
      "source": "/rowing",
      "destination": "/rowing/",
      "permanent": true
    },
    {
      "source": "/rowing-checklist",
      "destination": "/rowing-checklist/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/rowing-checklist/",
      "destination": "https://thewhitejersey-rowing-checklist.vercel.app/"
    },
    {
      "source": "/rowing-checklist/:path*",
      "destination": "https://thewhitejersey-rowing-checklist.vercel.app/:path*"
    },
    {
      "source": "/workout-app",
      "destination": "https://workout-app-chi-gray.vercel.app/index.html"
    },
    {
      "source": "/workout-app/:path*",
      "destination": "https://workout-app-chi-gray.vercel.app/:path*"
    },
    {
      "source": "/zone-calc",
      "destination": "https://zones-mu.vercel.app/index.html"
    },
    {
      "source": "/zone-calc/:path*",
      "destination": "https://zones-mu.vercel.app/:path*"
    },
    {
      "source": "/api/auth/:path*",
      "destination": "https://thewhitejersey-ika2.vercel.app/api/auth/:path*"
    },
    {
      "source": "/api/log/:path*",
      "destination": "https://thewhitejersey-ika2.vercel.app/api/log/:path*"
    },
    {
      "source": "/rowing/",
      "destination": "https://thewhitejersey-ika2.vercel.app/"
    },
    {
      "source": "/rowing/:path*",
      "destination": "https://thewhitejersey-ika2.vercel.app/:path*"
    }
  ]
}